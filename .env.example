# ================================================================
# BLOASIS Development Environment Variables
# Copy this file: cp .env.example .env, then fill in real values.
# ================================================================

# ── Infrastructure ────────────────────────────────────────────────
POSTGRES_DB=bloasis
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/bloasis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
LOG_LEVEL=INFO

# ── AI / LLM ─────────────────────────────────────────────────────
# LLM model (litellm format), API key, and optional custom endpoint.
# Examples:
#   anthropic/claude-haiku-4-5-20251001   (Anthropic — default)
#   ollama_chat/llama3.1:8b               (local Ollama — no key needed)
#   openai/gpt-4o-mini                    (OpenAI)
LLM_MODEL=anthropic/claude-haiku-4-5-20251001
LLM_API_KEY=
LLM_API_BASE=

# ── External Market Data ──────────────────────────────────────────
FRED_API_KEY=

# ── Authentication (Supabase Auth) ──────────────────────────────
SUPABASE_URL=http://localhost:54321
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ── Credential Encryption (required for broker config) ───────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=

# ── Alpaca Broker (optional — configure via Settings UI or env) ──
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER=true

# Set to true to enable mock broker (simulated fills without Alpaca keys)
MOCK_BROKER_ENABLED=false

# Set to true to enable periodic analysis for active trading users
SCHEDULER_ENABLED=false
ANALYSIS_INTERVAL_SECONDS=600

# ── Frontend ─────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=/api
