# BLOASIS environment variables.
# Copy to .env and fill in. .env is gitignored.

# === LLM (sentiment analysis) ===
# LiteLLM-compatible. Anthropic recommended for cost (Haiku).
ANTHROPIC_API_KEY=

# === News data ===
# Finnhub free tier: 60 calls/min. Sign up at https://finnhub.io
FINNHUB_API_KEY=

# === Broker (paper trading by default) ===
# Get keys from https://alpaca.markets (paper account)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true

# === Database ===
# Defaults to ./bloasis.db if unset
BLOASIS_DB_PATH=./bloasis.db

# === Logging ===
# DEBUG, INFO, WARNING, ERROR
BLOASIS_LOG_LEVEL=INFO
