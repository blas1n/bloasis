# BLOASIS environment variables.
# Copy to .env and fill in. .env is gitignored.

# === LLM (provider-agnostic via LiteLLM) ===
# Works with any LiteLLM-supported provider: Anthropic, OpenAI, Azure,
# Google, Ollama, etc. The model string carries the provider prefix.
#
# Examples:
#   LLM_MODEL=anthropic/claude-haiku-4-5-20251001
#   LLM_MODEL=openai/gpt-4o-mini
#   LLM_MODEL=azure/my-deployment-name
#   LLM_MODEL=ollama/llama3
#
# LLM_BASE_URL is optional — set for Azure, OpenAI-compatible proxies,
# self-hosted Ollama, etc. Leave blank for the provider's default.
LLM_API_KEY=
LLM_MODEL=anthropic/claude-haiku-4-5-20251001
LLM_BASE_URL=

# === News data ===
# Finnhub free tier: 60 calls/min. Sign up at https://finnhub.io
FINNHUB_API_KEY=

# === Broker (paper trading by default) ===
# Get keys from https://alpaca.markets (paper account)
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true

# === Database ===
# Defaults to ./bloasis.db if unset
BLOASIS_DB_PATH=./bloasis.db

# === Logging ===
# DEBUG, INFO, WARNING, ERROR
BLOASIS_LOG_LEVEL=INFO
