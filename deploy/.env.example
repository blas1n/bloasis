# =============================================================================
# BLOASIS Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git!
# =============================================================================

# ── Infrastructure: PostgreSQL ───────────────────────────────────
POSTGRES_DB=bloasis
POSTGRES_USER=postgres
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql+asyncpg://postgres:your_secure_password_here@postgres:5432/bloasis

# ── Infrastructure: Redis ────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── AI / LLM ────────────────────────────────────────────────────
# LLM model (litellm format), API key, and optional custom endpoint.
# Examples:
#   anthropic/claude-haiku-4-5-20251001   (Anthropic — default)
#   ollama_chat/llama3.1:8b               (local Ollama — no key needed)
#   openai/gpt-4o-mini                    (OpenAI)
LLM_MODEL=anthropic/claude-haiku-4-5-20251001
LLM_API_KEY=your_llm_api_key_here
LLM_API_BASE=

# ── External Market Data ────────────────────────────────────────
# FRED API (Federal Reserve Economic Data)
# Get your free API key from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# ── Authentication (Supabase Auth) ─────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=your-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ── Credential Encryption (required for broker config) ──────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPTION_KEY=your_fernet_key_here

# ── Alpaca Broker ────────────────────────────────────────────────
# Credentials can also be configured via Settings UI (stored encrypted in DB).
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER=true

# Set to true to enable mock broker (simulated fills without Alpaca keys)
MOCK_BROKER_ENABLED=false

# ── Trading Scheduler ───────────────────────────────────────────
# Set to true to enable periodic analysis for active trading users
SCHEDULER_ENABLED=false
ANALYSIS_INTERVAL_SECONDS=600

# ── Logging ──────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# Production Checklist
# =============================================================================
# Before deploying to production, ensure:
# [ ] All passwords are strong and randomly generated
# [ ] ALPACA_PAPER=true until ready for live trading
# [ ] Supabase JWT secret and service role key are configured
# [ ] LLM_API_KEY is set for AI-powered regime classification
# [ ] Database backups are configured
# [ ] Secrets are stored securely (not in git)
# =============================================================================
