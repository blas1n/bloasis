# API Configuration (Next.js API routes → FastAPI backend)
# Docker: use container name for internal communication
# Local: use localhost
API_URL=http://app:8000

# E2E Test Configuration (required for `npx playwright test`)
# E2E_FRONTEND_URL=http://localhost:3000
# E2E_API_URL=http://localhost:8000
# E2E_DEMO_EMAIL=your_test_user@example.com
# E2E_DEMO_PASSWORD=your_test_password
# E2E_USER_ID=your_test_user_uuid
